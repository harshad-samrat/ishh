<div class="floating" id="floating"></div>

  <div class="container">
    <h1>Bless You My Princess 💖</h1>
    <p class="tagline">
      Yeh reels sirf tere liye hain... Har ek ke neeche apna jawab likh dena behen agar kuch kehna ho to ✨<br>
      jruri nhi hai hr reel ka jawab but  jiska tuze lg rha hai uska bhej de
    </p>

    <div class="skip">
      <a href="/ishh/feedback"><button>Skip this page if you want</button></a>
    </div>

    <div class="reels-grid">

      <% 
        const reels = [
          { id: 1, src: "/assets/videos/1.mp4", caption: "Reel 1" },
          { id: 3, src: "/assets/videos/3.mp4", caption: "Reel 3" },       
          { id: 5, src: "/assets/videos/5.mp4", caption: "Reel 5" },
          { id: 7, src: "/assets/videos/7.mp4", caption: "Reel 7" },
          { id: 8, src: "/assets/videos/8.mp4", caption: "Reel 8 isk answer jrur dena" },
          { id: 9, src: "/assets/videos/9.mp4", caption: "Reel 9" },
          { id: 10, src: "/assets/videos/10.mp4", caption: "Reel 10" },
          { id: 11, src: "/assets/videos/11.mp4", caption: "Reel 11" },
          { id: 12, src: "/assets/videos/12.mp4", caption: "Reel 12" },
          { id: 13, src: "/assets/videos/13.mp4", caption: "Reel 13" },
          { id: 14, src: "/assets/videos/14.mp4", caption: "Reel 14" },
          { id: 15, src: "/assets/videos/15.mp4", caption: "Reel 15" },
          { id: 17, src: "/assets/videos/17.mp4", caption: "Reel 17 \n smji kyaa...!log trs rhe muje milne" },
          { id: 18, src: "/assets/videos/18.mp4", caption: "Reel 18" },
          { id: 19, src: "/assets/videos/19.mp4", caption: "Reel 19" },
          { id: 20, src: "/assets/videos/20.mp4", caption: "Reel 20" },
          { id: 21, src: "/assets/videos/21.mp4", caption: "Reel 21 iska bhi jawab dena yr taki me bhi clear ho jau" }
        ];
      %>

      <% reels.forEach(reel => { %>
        <div class="reel-card">
          <div class="video-container">
            <video controls loop muted>
              <source src="<%= reel.src %>" type="video/mp4">
            </video>
          </div>
          <div class="reel-info">
            <h3><%= reel.caption %></h3>
            <textarea placeholder="Write answer behen here... 💕" id="answer-<%= reel.id %>"></textarea>
            <button class="submit-btn" onclick="submitAnswer(<%= reel.id %>)">
              <i class="fas fa-paper-plane"></i> Send to Bhaiya
            </button>
            <p class="success-msg" id="success-<%= reel.id %>">💖 Jawab save ho gaya!</p>
          </div>
        </div>
      <% }); %>

    </div>
  </div>
  <div class="skip" style="z-index: 1;">
    <a href="/ishh/feedback"><button>Bore ho gyi...! Chlo aage badhte hai</button></a>
  </div>
 
  <script>
    // Auto unmute when video is played
    document.addEventListener('play', function(e) {
      if (e.target.tagName === 'VIDEO') {
        e.target.muted = false;
      }
    }, true);

    async function submitAnswer(reelId) {
      const textarea = document.getElementById(`answer-${reelId}`);
      const answer = textarea.value.trim();
      const successMsg = document.getElementById(`success-${reelId}`);

      if (!answer) {
        alert("Please write something sweet 💕");
        return;
      }

      try {
        const res = await fetch("/ishh/reels/answer", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ reelId, answer })
        });

        const data = await res.json();

        if (data.success) {
          successMsg.style.display = "block";
          textarea.value = "";
          setTimeout(() => successMsg.style.display = "none", 4000);
        }
      } catch (err) {
        alert("Something went wrong 😢");
      }
    }

    // Floating Animation
    function createFloating() {
      const emojis = ["💖","🌸","🦋","✨","💕","👑","🌷","💗"];
      const span = document.createElement("span");
      span.textContent = emojis[Math.floor(Math.random()*emojis.length)];
      span.style.position = "absolute";
      span.style.left = Math.random() * 100 + "%";
      span.style.bottom = "-60px";
      span.style.fontSize = (Math.random()*2.6 + 2.2) + "rem";
      span.style.opacity = Math.random() * 0.7 + 0.6;
      span.style.animation = `floatUp ${Math.random()*13 + 15}s linear forwards`;
      document.getElementById("floating").appendChild(span);
      setTimeout(() => span.remove(), 45000);
    }

    window.onload = () => {
      for(let i = 0; i < 20; i++) setTimeout(createFloating, i * 180);
      setInterval(createFloating, 380);
    };

    const style = document.createElement('style');
    style.innerHTML = `
      @keyframes floatUp {
        0% { transform: translateY(0) rotate(0deg); opacity: 0.9; }
        100% { transform: translateY(-130vh) rotate(30deg); opacity: 0; }
      }
    `;
    document.head.appendChild(style);
  </script>