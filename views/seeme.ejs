          </audio>
        </div>`;
    }
  }
  // Random Moving Button (Bore Button)
  const boreBtn = document.getElementById("boreBtn");

  boreBtn.addEventListener("mouseenter", () => {
    const x = Math.random() * (window.innerWidth - 300);
    const y = Math.random() * (window.innerHeight - 200);

    boreBtn.style.position = "fixed";
    boreBtn.style.left = x + "px";
    boreBtn.style.top = y + "px";
    boreBtn.style.transition = "all 0.6s ease";
  });

  // Optional: Make it move continuously on hover
  boreBtn.addEventListener("mousemove", () => {
    const x = Math.random() * (window.innerWidth - 300);
    const y = Math.random() * (window.innerHeight - 200);
    boreBtn.style.left = x + "px";
    boreBtn.style.top = y + "px";
