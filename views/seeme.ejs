<style>
  body {
    font-family: "Poppins", sans-serif;
    text-align: center;
    padding: 50px;
    background: #1a1a2e;
    color: white;
  }
  .success {
    color: #4ade80;
    font-size: 1.5rem;
  }
</style>
<div class="floating" id="floating"></div>

<div class="container">
  <h1>My Memories for You 💖</h1>

  <!-- Photos Section -->
  <div class="section">
    <h2 class="section-title">📸 My Photos</h2>
    <div class="cards-grid" id="photosGrid"></div>
  </div>

  <!-- Videos Section -->
  <div class="section">
    <h2 class="section-title">🎥 My Videos</h2>
    <div class="cards-grid" id="videosGrid"></div>
  </div>

  <!-- Audios Section -->
  <div class="section">
    <h2 class="section-title">🎙️ My Voice Notes</h2>
    <div class="cards-grid" id="audiosGrid"></div>
  </div>
  <h1>You can send your image here to meee siso</h1>
  <p>tum multiple images bhej sakte ho..! darling</p>

  <div class="image">
    <form
      action="/ishh/upload-memory"
      method="POST"
      enctype="multipart/form-data"
    >
      <textarea name="note" placeholder="Add a note..."></textarea><br /><br />
      <input type="file" name="image" accept="image/*" required /><br /><br />
      <button type="submit">add image</button>
    </form>
  </div>
  <!-- Fun Dual Buttons -->
  <div class="final-buttons">
    <button class="btn-fun" id="boreBtn">Bore ho gyi princess 😴</button>

    <button class="btn-next" onclick="window.location.href = '/ishh/myfeeling'">
