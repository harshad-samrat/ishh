  // Floating Animation
  function createFloating() {
    const emojis = ["💖", "❤️", "🌸", "🦋", "✨", "💕", "👑"];
    const span = document.createElement("span");
    span.textContent = emojis[Math.floor(Math.random() * emojis.length)];
    span.style.position = "absolute";
    span.style.left = Math.random() * 100 + "%";
    span.style.bottom = "-60px";
    span.style.fontSize = Math.random() * 2.8 + 2.2 + "rem";
    span.style.opacity = Math.random() * 0.8 + 0.6;
    span.style.animation = `floatUp ${Math.random() * 14 + 16}s linear forwards`;
    document.getElementById("floating").appendChild(span);
    setTimeout(() => span.remove(), 50000);
  }

  window.onload = () => {
    for (let i = 0; i < 18; i++) setTimeout(createFloating, i * 200);
    setInterval(createFloating, 400);
    renderPhotos();
    renderVideos();
    renderAudios();
  };

