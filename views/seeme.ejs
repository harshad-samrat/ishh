                <source src="/assets/mypic/video/${video.num}.mp4" type="video/mp4">
              </video>
              <p class="note">${video.note}</p>
            </div>
          </div>
        </div>`;
    });
  }

  // ================== AUDIOS ==================
  function renderAudios() {
    const grid = document.getElementById("audiosGrid");
    for (let i = 1; i <= 2; i++) {
      grid.innerHTML += `
        <div class="audio-player">
          <h3>Voice Note ${i} 🎙️</h3>
          <audio controls style="width:100%;">
