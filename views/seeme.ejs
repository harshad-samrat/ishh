        0% { transform: translateY(0) rotate(0deg); }
        100% { transform: translateY(-130vh) rotate(35deg); opacity: 0; }
      }

      .flip-card-back {
        display: flex;
        flex-direction: column;
        padding: 15px;
      }

      .flip-card-back img,
      .flip-card-back video {
        width: 100%;
        height: 380px;
        object-fit: cover;
        border-radius: 18px;
        margin-bottom: 15px;
      }

      .note {
        margin-top: auto;
        font-size: 1.18rem;
        color: var(--hot-pink);
        font-style: italic;
        text-align: center;
        line-height: 1.5;
      }

      /* ============== GIRLY AUDIO PLAYER ============== */
      .audio-player {
        background: linear-gradient(145deg, #fff0f5, #ffe4f0);
        padding: 25px 20px;
        border-radius: 25px;
        box-shadow: 0 15px 35px rgba(233, 30, 99, 0.25);
        text-align: center;
        border: 3px solid var(--soft-pink);
        margin: 25px auto;
        max-width: 380px;
      }

      .audio-player h3 {
        color: var(--hot-pink);
        margin-bottom: 15px;
        font-size: 1.4rem;
      }

      .audio-player audio {
        width: 100%;
        border-radius: 15px;
        background: white;
      }

      .audio-player audio::-webkit-media-controls-panel {
        background: rgba(255, 240, 245, 0.9);
      }
    `;
  document.head.appendChild(style);
  // Disable right click
  document.addEventListener("contextmenu", (e) => {
    if (
      e.target.tagName === "IMG" ||
      e.target.tagName === "VIDEO" ||
      e.target.tagName === "AUDIO"
