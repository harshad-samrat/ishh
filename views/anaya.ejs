<script>
  // Floating hearts, sparkles & crowns
  function createFloatingElement() {
    const elements = ["💖", "🌸", "✨", "👑", "🍭", "🦋", "💗", "⭐"];
    const floating = document.getElementById("floating");
    const span = document.createElement("span");

    span.textContent = elements[Math.floor(Math.random() * elements.length)];
    span.style.left = Math.random() * 100 + "%";
    span.style.animationDuration = Math.random() * 8 + 9 + "s";
    span.style.fontSize = Math.random() * 1.4 + 1.8 + "rem";
    span.style.opacity = Math.random() * 0.7 + 0.6;

    floating.appendChild(span);

    setTimeout(() => span.remove(), 20000);
  }

  // Create multiple floating elements
  setInterval(createFloatingElement, 280);
  for (let i = 0; i < 12; i++) {
    setTimeout(createFloatingElement, i * 200);
  }

  // Flip Card
  function flipTheCard() {
    const card = document.getElementById("cardInner");
    card.classList.toggle("is-flipped");
    card.scrollIntoView({ behavior: "smooth", block: "center" });
  }

  // Keyboard surprise
  document.addEventListener("keydown", (e) => {
    if (e.key === "p" || e.key === "P") {
      document.body.style.transition = "filter 0.6s";
      document.body.style.filter = "hue-rotate(20deg) saturate(1.4)";
      setTimeout(() => (document.body.style.filter = ""), 1200);
    }
  });
</script>
