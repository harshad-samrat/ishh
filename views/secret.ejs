<div class="floating-elements" id="floating"></div>

<div class="container">
  <h1>Secret IDs 👀</h1>
  <p class="tagline">
    Mujhe shayad lag raha hai ki kisi chuje ne tume bata diya hoga ye meri
    IDs...<br />
    Mana karne ke bawajood bhi , fir bhi dek Lo 💖
  </p>

  <div class="cards-grid">
    <!-- Card 1 -->
    <div class="flip-card" id="card1" onclick="flipCard(1)">
      <div class="flip-card-inner">
        <div class="flip-card-front">
          <h3 style="color: var(--dark-pink); margin-bottom: 20px">
            ID xxx1<br />click to reveal
          </h3>
          <i class="fas fa-lock" style="font-size: 4rem; color: #ccc"></i>
        </div>
        <div class="flip-card-back">
          <img src="/assets/english.png" class="card-img" alt="English ID" />
        </div>
      </div>
    </div>

    <!-- Card 2 -->
    <div class="flip-card" id="card2" onclick="flipCard(2)">
      <div class="flip-card-inner">
        <div class="flip-card-front">
          <h3 style="color: var(--dark-pink); margin-bottom: 20px">
            ID xxx2 <br />click to reveal
          </h3>
          <i class="fas fa-lock" style="font-size: 4rem; color: #ccc"></i>
        </div>
        <div class="flip-card-back">
          <img src="/assets/mic.png" class="card-img" alt="Mic ID" />
        </div>
      </div>
    </div>
  </div>

  <!-- Note after both flipped -->
  <div class="note" id="note">
    Meri aur bhi IDs hai but ye dono se hi maine baat ki thi toh yahi bata raha
    hu 💕
  </div>

  <!-- Message Form -->
  <div class="form-section">
    <h2 style="color: var(--dark-pink)">💌 me sorry toh hu</h2>
    <p class="tip">pr fir bhi shikayaat hai to btao yaha pe❤️</p>

    <form action="/ishh/msgtome/secret" method="POST">
      <textarea
        name="message"
        placeholder="Bhaiya, yahan apni baat likho..."
        required
      ></textarea
      ><br />
      <button type="submit" class="send-btn">
        Send Message 💌 to my cute brother
      </button>
    </form>
  </div>

  <button onclick="goForward()" class="forward-btn" id="forwardBtn">
    Chlo Mere Pyare Bhaiya, Ab Aage Badhte Hai ✨
  </button>
</div>

<script>
  // Boolean from EJS
  const hasSubmitted = <%= hasSubmittedMessage ? 'true' : 'false' %>;
  console.log("Has Submitted Message:", hasSubmitted);
  let flippedCards = 0;

  function flipCard(cardNum) {
      const card = document.getElementById(`card${cardNum}`);
      if (!card.classList.contains('flipped')) {
          card.classList.add('flipped');
          flippedCards++;

          if (flippedCards === 2) {
              document.getElementById("note").style.display = "block";
          }
      }
  }

  function goForward() {
      if (!hasSubmitted) {
          alert("💖 Princess, pehle ek message toh bhejo apne bhaiya ko...\nBina message ke aage nahi ja sakte! 😊");
          return;
      }
      // If message exists
      window.location.href = "/ishh/reels";
  }

  // Floating Animation
  function createFloating() {
      const emojis = ["💖", "💅", "✨", "🌸", "🦋", "💕", "🌷"];
      const span = document.createElement("span");

      span.textContent = emojis[Math.floor(Math.random() * emojis.length)];
      span.style.position = "absolute";
      span.style.left = Math.random() * 100 + "%";
      span.style.bottom = "-60px";
      span.style.fontSize = (Math.random() * 2.2 + 2.3) + "rem";
      span.style.opacity = Math.random() * 0.5 + 0.65;
      span.style.animation = `floatUp ${Math.random() * 13 + 15}s linear forwards`;
      span.style.zIndex = "-1";

      document.getElementById("floating").appendChild(span);
      setTimeout(() => span.remove(), 45000);
  }

  // Initialize floating elements
  window.onload = function() {
      // Start floating hearts
      for(let i = 0; i < 14; i++) {
          setTimeout(createFloating, i * 170);
      }
      setInterval(createFloating, 350);
  };
</script>
