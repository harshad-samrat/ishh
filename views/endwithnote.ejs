  <style>
    :root {
      --pink: #ff1493;
      --dark-pink: #e91e63;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: "Poppins", sans-serif;
      background: url('/assets/videos/blessme.jpg') center/cover no-repeat fixed;
      min-height: 100vh;
      color: white;
      position: relative;
      overflow-y: auto;
      padding: 20px;
    }

    .overlay {
      position: fixed;
      top: 0; left: 0;
      width: 100%; height: 100%;
      background: rgba(0, 0, 0, 0.55);
      z-index: 1;
    }

    .container {
      position: relative;
      z-index: 2;
      max-width: 720px;
      margin: 40px auto;
      text-align: center;
    }

    h1 {
      font-family: "Dancing Script", cursive;
      font-size: 5.2rem;
      color: #ff1493;
      text-shadow: 0 10px 30px rgba(0,0,0,0.7);
      margin-bottom: 30px;
      line-height: 1.1;
    }

    .message {
      font-size: 1.45rem;
      line-height: 2;
      background: rgba(255,255,255,0.15);
      padding: 40px;
      border-radius: 30px;
      backdrop-filter: blur(12px);
      border: 4px solid rgba(255, 20, 147, 0.4);
      margin-bottom: 50px;
    }

    .player-container {
      background: rgba(255,255,255,0.95);
      padding: 25px;
      border-radius: 25px;
      box-shadow: 0 15px 40px rgba(0,0,0,0.3);
      margin-bottom: 50px;
    }

    audio {
      width: 100%;
    }

    .final-btn {
      padding: 20px 70px;
      background: linear-gradient(45deg, #ff1493, #db2777);
      color: white;
      border: none;
      border-radius: 50px;
      font-size: 1.5rem;
      cursor: pointer;
      box-shadow: 0 15px 40px rgba(255, 20, 147, 0.4);
    }
  </style>
</head>
<body>

  <div class="overlay"></div>

  <div class="container">
    <h1>Mein Hamesha Tumhare Saath Hu 💖</h1>

    <div class="message">
      Chahe tume meri zarurat ho ya na ho,<br>
      Tum mujhe ignore kro, avoid kro,<br>
      Mujhe bhai mano ya na mano...<br><br>
      
      <strong>Mein hamesha tumhare saath hu.</strong><br><br>
      
      Jab bhi tume lage ki koi nahi hai...<br>
      Bas awaaz de dena, main aa jaunga. 🌸
    </div>

    <!-- Attractive Audio Player -->
    <div class="player-container">
      <h3 style="color: var(--dark-pink); margin-bottom: 15px;">🎵 Tere Saath - Special Song</h3>
      <audio id="finalAudio" controls autoplay loop>
        <source src="/assets/mypic/audio/2.mp3" type="audio/mpeg">
      </audio>
    </div>

    <button onclick="finalGoodbye()" class="final-btn">
      Byyy Bhaiya... Love You 💕
    </button>
  </div>

  <script>
    // Strong Autoplay
    window.addEventListener("load", () => {
      const audio = document.getElementById("finalAudio");
      audio.play().catch(() => {});
    });

    function finalGoodbye() {
      alert("❤️ I Love You Too My Princess... Hamesha Khush Rahna ✨");
      window.location.href = "/ishh";
    }

    // Floating Hearts
    function createFloating() {
      const span = document.createElement("span");
      span.textContent = ['💖','🌸','✨','👑','💕'][Math.floor(Math.random()*5)];
      span.style.position = 'fixed';
      span.style.left = Math.random() * 100 + '%';
      span.style.fontSize = (Math.random() * 2.2 + 2.5) + 'rem';
      span.style.animation = `floatUp ${Math.random()*10 + 13}s linear infinite`;
      span.style.opacity = 0.8;
      span.style.zIndex = 10;
      document.body.appendChild(span);
      setTimeout(() => span.remove(), 40000);
    }

    setInterval(createFloating, 300);
    for (let i = 0; i < 18; i++) setTimeout(createFloating, i * 180);

    const style = document.createElement('style');
    style.innerHTML = `
      @keyframes floatUp {
        0% { transform: translateY(100vh) rotate(0deg); }
        100% { transform: translateY(-120vh) rotate(720deg); }
      }
    `;
    document.head.appendChild(style);
  </script>